// AssetFlow — Prisma Schema
// Database: Supabase PostgreSQL
// Use DATABASE_URL for migrations (direct), DATABASE_URL_POOL for queries (pgbouncer)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ============================================================
// ENUMERATIONS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  ASSET_MANAGER
  TECHNICIAN
  VIEWER

  @@map("user_role")
}

enum OrgPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE

  @@map("org_plan")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  VIEW
  EXPORT
  IMPORT
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_RESET
  PERMISSION_CHANGE
  ROLE_CHANGE
  APPROVE
  REJECT
  ASSIGN
  UNASSIGN

  @@map("audit_action")
}

enum AuditResource {
  USER
  ORGANIZATION
  ASSET
  MAINTENANCE_ORDER
  PROCUREMENT_REQUEST
  DEPRECIATION_ENTRY
  LOCATION
  DOCUMENT
  REPORT
  SETTINGS

  @@map("audit_resource")
}

// ============================================================
// ORGANIZATIONS
// ============================================================

model Organization {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @db.VarChar(255)
  slug      String    @unique @db.VarChar(100)
  logoUrl   String?   @map("logo_url") @db.VarChar(512)
  plan      OrgPlan   @default(FREE)
  isActive  Boolean   @default(true) @map("is_active")
  settings  Json      @default("{}")
  metadata  Json      @default("{}")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  members   OrgMember[]
  profiles  Profile[]
  auditLogs AuditLog[]

  @@index([slug])
  @@index([isActive])
  @@index([deletedAt])
  @@map("organizations")
}

// ============================================================
// PROFILES (mirrors Supabase auth.users — one-to-one)
// ============================================================

model Profile {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  orgId       String?   @map("org_id") @db.Uuid
  firstName   String    @map("first_name") @db.VarChar(100)
  lastName    String    @map("last_name") @db.VarChar(100)
  displayName String    @map("display_name") @db.VarChar(200)
  avatarUrl   String?   @map("avatar_url") @db.VarChar(512)
  phone       String?   @db.VarChar(50)
  timezone    String    @default("UTC") @db.VarChar(50)
  locale      String    @default("en") @db.VarChar(10)
  role        UserRole  @default(VIEWER)
  isActive    Boolean   @default(true) @map("is_active")
  preferences Json      @default("{}")
  lastSeenAt  DateTime? @map("last_seen_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  org         Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  memberships OrgMember[]
  auditLogs   AuditLog[]

  @@index([userId])
  @@index([orgId])
  @@index([role])
  @@index([isActive])
  @@map("profiles")
}

// ============================================================
// ORGANIZATION MEMBERSHIPS
// ============================================================

model OrgMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  role      UserRole @default(VIEWER)
  isActive  Boolean  @default(true) @map("is_active")
  invitedBy String?  @map("invited_by") @db.Uuid
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  profile Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([orgId, profileId])
  @@index([orgId])
  @@index([profileId])
  @@index([role])
  @@map("org_members")
}

// ============================================================
// ROLES & PERMISSIONS (fine-grained RBAC — future-ready)
// ============================================================

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String?  @map("org_id") @db.Uuid
  name        String   @db.VarChar(100)
  displayName String   @map("display_name") @db.VarChar(200)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  metadata    Json     @default("{}")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  permissions RolePermission[]

  @@unique([orgId, name])
  @@index([orgId])
  @@index([isSystem])
  @@map("roles")
}

model Permission {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique @db.VarChar(100)
  name        String  @db.VarChar(200)
  description String? @db.Text
  module      String  @db.VarChar(50)
  isSystem    Boolean @default(true) @map("is_system")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at") @db.Timestamptz
  grantedBy    String?  @map("granted_by") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ============================================================
// AUDIT LOG (append-only — no updates, no hard deletes)
// ============================================================

model AuditLog {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String?       @map("org_id") @db.Uuid
  userId     String?       @map("user_id") @db.Uuid
  action     AuditAction
  resource   AuditResource
  resourceId String?       @map("resource_id") @db.Uuid
  oldValues  Json?         @map("old_values")
  newValues  Json?         @map("new_values")
  metadata   Json?
  ipAddress  String?       @map("ip_address") @db.VarChar(45)
  userAgent  String?       @map("user_agent") @db.VarChar(512)
  requestId  String?       @map("request_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  org     Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  profile Profile?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}
