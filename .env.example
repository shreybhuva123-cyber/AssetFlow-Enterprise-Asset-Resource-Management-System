# ============================================================
# AssetFlow — Environment Variables Reference
# ============================================================
# Copy this file to .env.local and populate with your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase (Required) ---
# Found in: Supabase Dashboard → Settings → API

# Your project's API URL
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SECRET. Server-side ONLY. Never send to the client.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret — used to verify tokens server-side
SUPABASE_JWT_SECRET=

# --- Database (Required for Prisma) ---
# Found in: Supabase Dashboard → Settings → Database → Connection string

# Direct connection — used for Prisma migrations (not pgbouncer)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Pooled connection — used for Prisma queries in serverless environments
# Add ?pgbouncer=true&connection_limit=1 for Vercel/serverless
DATABASE_URL_POOL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AssetFlow
NEXT_PUBLIC_APP_VERSION=0.1.0

# --- Storage Bucket Names ---
# These must match the bucket names created in your Supabase project
NEXT_PUBLIC_STORAGE_BUCKET_ASSET_IMAGES=asset-images
NEXT_PUBLIC_STORAGE_BUCKET_ASSET_DOCUMENTS=asset-documents
NEXT_PUBLIC_STORAGE_BUCKET_AVATARS=avatars
NEXT_PUBLIC_STORAGE_BUCKET_EXPORTS=exports

# --- Feature Flags (optional — defaults defined in src/constants/features.ts) ---
NEXT_PUBLIC_FF_REALTIME_DASHBOARD=true
NEXT_PUBLIC_FF_ADVANCED_ANALYTICS=true
NEXT_PUBLIC_FF_QR_CODE_ASSET_TAGS=true
NEXT_PUBLIC_FF_CALENDAR_INTEGRATION=true
NEXT_PUBLIC_FF_AI_PREDICTIVE_MAINTENANCE=false

# --- Analytics (optional) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Environment ---
NODE_ENV=development
